#!/usr/bin/env node
"use strict";

const path = require("path");
const fs = require("fs");

// Resolve the dist directory relative to this script
const scriptDir = __dirname;
const distDir = path.join(scriptDir, "..", "dist");
const entryPoint = path.join(distDir, "index.js");

// Verify the entry point exists
if (!fs.existsSync(entryPoint)) {
  console.error("Error: dist/index.js not found. Please run 'npm run build' first.");
  process.exit(1);
}

// Load and execute the entry point
require(entryPoint);
